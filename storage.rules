rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Aturan untuk avatar pengguna
    // Path: /avatars/{userId}/{fileName}
    match /avatars/{userId}/{fileName} {
      
      // Siapa pun dapat membaca avatar (untuk ditampilkan di profil, papan peringkat, dll.)
      allow read: if true;
      
      // Hanya pengguna yang terautentikasi dan cocok dengan userId yang dapat membuat/memperbarui file.
      allow create, update: if request.auth != null && request.auth.uid == userId
                        // Validasi tipe file (hanya gambar)
                        && request.resource.contentType.matches('image/.*')
                        // Validasi ukuran file (misalnya, maksimal 5MB)
                        && request.resource.size < 5 * 1024 * 1024;

      // Hanya pengguna yang terautentikasi dan cocok dengan userId yang dapat menghapus file.
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Aturan untuk file PDF materi
    // Path: /materi_pdf/{fileName}
    match /materi_pdf/{fileName} {
      // Izinkan semua pengguna terautentikasi untuk membaca file PDF materi
      allow read: if request.auth != null;
      
      // Izinkan semua pengguna terautentikasi untuk mengunggah dan memperbarui file materi (maksimal 20MB)
      // Catatan: Keamanan akhir dijamin oleh aturan Firestore pada koleksi 'chapters' yang membatasi perubahan hanya untuk admin.
      allow create, update: if request.auth != null
                        && request.resource.contentType == 'application/pdf'
                        && request.resource.size < 20 * 1024 * 1024;

      // Izinkan semua pengguna terautentikasi untuk menghapus file materi
      allow delete: if request.auth != null;
    }
  }
}
